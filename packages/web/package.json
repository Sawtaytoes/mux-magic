    "js-yaml": "^4.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.0"
  },
  "devDependencies": {
    "@mux-magic/api": "workspace:*",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "^10.3.6",
