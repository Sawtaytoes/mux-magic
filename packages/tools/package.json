{
  "name": "@mux-magic/tools",
  "version": "1.2.2",
  "type": "module",
  "description": "Reusable utilities (file system, logging, rxjs operators) shared between @mux-magic/api and sibling tools like Gallery-Downloader.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test-helpers": {
      "source": "./src/test-helpers.ts",
      "types": "./dist/test-helpers.d.ts",
      "default": "./dist/test-helpers.js"
    },
    "./src/*": "./src/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sawtaytoes/mux-magic.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "yarn build",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "fast-sort": "^3.4.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "memfs": "^4.57.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
