{
  "name": "mux-magic",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:command-descriptions": "yarn workspace @mux-magic/api build:command-descriptions",
    "build:prod": "yarn build:version && yarn build:command-descriptions && yarn build:web-static && yarn build:server-bundle",
    "build:server-bundle": "esbuild --format=esm --bundle --platform=node --sourcemap \"--banner:js=import{createRequire}from'node:module';const require=createRequire(import.meta.url);\" --external:./xhr-sync-worker.js \"--external:chromium-bidi/*\" --external:playwright --external:playwright-core --external:vite --outfile=packages/server/dist/index.js packages/server/src/index.ts",
    "build:tools": "yarn workspace @mux-magic/tools build",
    "build:version": "node scripts/build-version.cjs",
    "build:web-static": "yarn workspace @mux-magic/web build",
    "cli-app:build": "rimraf build/ && esbuild --format=cjs --minify --bundle --platform=node --external:./xhr-sync-worker.js \"--external:chromium-bidi/*\" --outfile=build/mux-magic.cjs packages/cli/src/cli.ts",
    "cli-app:copy-assets": "rimraf dist/assets && mkdir 'dist/assets' && npx cpx2 'assets/**/*' dist/assets/",
    "cli-app:sea": "rimraf dist/ && yarn cli-app:build && node --experimental-sea-config sea-config.json && mkdir dist && node -e \"require('fs').copyFileSync(process.execPath, 'dist/mux-magic.exe')\" && npx postject 'dist/mux-magic.exe' NODE_SEA_BLOB 'build/sea-prep.blob' --sentinel-fuse NODE_SEA_FUSE_fce680ab2cc467b6e072b8b5df1996b2 && yarn cli-app:copy-assets",
    "dev": "yarn workspace @mux-magic/server dev",
    "e2e:ui": "playwright test --ui",
    "e2e": "playwright test",
    "generate:external-api-schemas": "yarn workspace @mux-magic/api generate:external-api-schemas",
    "generate:internal-api-schemas:watch": "yarn workspace @mux-magic/api generate:internal-api-schemas:watch",
    "generate:internal-api-schemas": "yarn workspace @mux-magic/api generate:internal-api-schemas",
    "generate:schemas-ci": "yarn build:version && yarn build:command-descriptions && yarn generate:internal-api-schemas && yarn build:web-static",
    "generate:screenshots": "yarn workspace @mux-magic/api generate:screenshots",
    "generate:seed-anidb-fixtures": "yarn workspace @mux-magic/api generate:seed-anidb-fixtures",
    "install-playwright-browser": "yarn playwright install chromium --with-deps",
    "lint:biome-format": "biome check --write --unsafe",
    "lint:biome": "biome check",
    "lint:eslint-format": "eslint . --fix",
    "lint:eslint": "eslint .",
    "lint": "yarn lint:biome-format && yarn lint:eslint-format",
    "media": "yarn workspace @mux-magic/cli cli",
    "prebuild": "yarn build:version && yarn build:command-descriptions",
    "predev": "yarn build:version && yarn build:command-descriptions",
    "preserver": "node scripts/copy-assets-to-worktree.cjs && yarn build:version && yarn build:command-descriptions",
    "prod:server": "node --enable-source-maps packages/server/dist/index.js",
    "start": "yarn dev",
    "storybook": "yarn workspace @mux-magic/web storybook",
    "test": "vitest",
    "typecheck": "tsc --noEmit && yarn workspaces foreach -Ap run typecheck"
  },
  "type": "module",
  "dependencies": {
    "fast-sort": "^3.4.1",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "@mux-magic/web": "workspace:*",
    "@playwright/mcp": "^0.0.75",
    "@playwright/test": "^1.59.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.6.2",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@yarnpkg/sdks": "^3.2.3",
    "cpx2": "^8.0.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "resolutions": {
    "mal-scraper@^2.13.2": "patch:mal-scraper@npm%3A2.13.2#./.yarn/patches/mal-scraper-npm-2.13.2-36efb47931.patch",
    "@babel/runtime": ">=7.26.10"
  }
}
