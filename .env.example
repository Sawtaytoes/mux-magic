PORT=3000
WEB_PORT=4173
# Concurrent thread limit for all commands. Important for lower-end systems —
# set to 2–4 to reduce memory/CPU usage. Defaults to CPU core count.
# MAX_THREADS=4
# Default per-job task concurrency claim. Each sequence job requests this many
# concurrent task slots from the global pool. Defaults to 2. Set to 0 or a
# negative value to fall back to MAX_THREADS (no per-job restriction).
# Clamped to MAX_THREADS if set higher. The UI's "Thread count" variable
# overrides this on a per-sequence basis.
# DEFAULT_THREAD_COUNT=2
# Maximum number of concurrent audio transcode jobs for browser audio playback fallback.
# Defaults to 4. Lower this on resource-constrained systems.
# MAX_TRANSCODE_CONCURRENCY=4
# Maximum size of the transcode cache directory in bytes.
# Defaults to 4294967296 (4 GB). Cache lives in os.tmpdir()/media-tools-transcode-cache/
# TRANSCODE_CACHE_MAX_BYTES=4294967296
# Where AniDB-related caches live (anime XML, DDG search HTML).
# Defaults to ./.cache/anidb (project-relative, gitignored). In Docker,
# point this at a mounted volume so caches survive container restarts.
# ANIDB_CACHE_FOLDER=/data/cache/anidb
# Where server-owned persistent state lives (saved sequence templates,
# queued webhook deliveries, etc.). Defaults to ./.config (project-relative,
# gitignored). In Docker, point this at a mounted volume so saved templates
# survive container restarts (e.g. /media/config).
# APP_DATA_DIR=/media/config
# Path to the MediaInfo CLI binary.
# Windows default: assets/mediainfo/MediaInfo.exe (place MediaInfo.exe there, or override here)
# Linux/Mac default: mediainfo (must be in PATH)
# MEDIAINFO_PATH=C:\Program Files\MediaInfo\MediaInfo.exe
TVDB_API_KEY=00000000-0000-0000-0000-000000000000
# TMDB v4 read-access token (NOT the v3 api_key). Generate one at
# https://www.themoviedb.org/settings/api after creating a v4 application.
# Sent as `Authorization: Bearer <token>` to api.themoviedb.org/3.
TMDB_API_KEY=replace-with-your-tmdb-v4-bearer-token
# Base URL the frontend uses for all API calls (e.g. https://example.com/api).
# Also sets the server URL in OpenAPI documentation.
# When unset, the frontend defaults to http://localhost:3000 (the Hono API
# server's default port). Set this when the API is on a different host/port.
# REMOTE_SERVER_URL=https://example.com/api
# Whether the file-explorer modal sends deletes to the OS Recycle Bin
# (default 'true') or unlinks them outright. Set to 'false' / '0' for
# environments where the OS trash isn't useful — e.g. the API server
# running inside a Docker container against a remote ZFS share, where
# filesystem snapshots are the recovery story instead of a per-OS
# Recycle Bin. Windows network drives (`G:` mapped to `\\\\server\\share`)
# are auto-downgraded to permanent at delete time even when this is
# 'true', because Windows' Recycle Bin can't service network shares.
# DELETE_TO_TRASH=true
# Set to 'true' or '1' to populate the UI with mock data
# (useful for development/screenshots).
# MEDIA_TOOLS_FAKE_DATA=true
#
# ── Home Assistant webhook integration ────────────────────────────────────────
#
# Outbound webhook URLs for job lifecycle events. Leave unset to disable that
# event's notification. If set but the POST fails, a warning is logged and the
# job continues normally (never crashes).
# WEBHOOK_JOB_STARTED_URL=http://homeassistant.local:8123/api/webhook/mux_job_started
# WEBHOOK_JOB_COMPLETED_URL=http://homeassistant.local:8123/api/webhook/mux_job_completed
# WEBHOOK_JOB_FAILED_URL=http://homeassistant.local:8123/api/webhook/mux_job_failed
# Fired once when the Node process is about to exit because of an
# uncaughtException or unhandledRejection (i.e. the server is crashing and
# the supervisor will restart it). One best-effort POST with a 5s timeout,
# then the process exits. Payload: { source, reason, stack, occurredAt }.
# WEBHOOK_PROCESS_CRASHED_URL=http://homeassistant.local:8123/api/webhook/mux_process_crashed
